nextflow.enable.dsl=2

params {
  reference       = null
  reads           = null
  model_path      = null
  sample          = null
  outdir          = "results"
  threads         = 4
  platform        = "hifi"
  minimap2_preset = "map-hifi"
  clair3_args     = ""
  use_local_sifs  = false
  sif_minimap2    = "${projectDir}/containers/minimap2.sif"
  sif_samtools    = "${projectDir}/containers/samtools.sif"
  sif_clair3      = "${projectDir}/containers/clair3.sif"
}

process {
  cpus = 4
  withName: "INDEX_REF_MINIMAP2" {
    memory = '2 GB'
    time   = '2h'
  }
  withName: "ALIGN_MINIMAP2" {
    memory = '8 GB'
    time   = '6h'
  }
  withName: "SORT_INDEX_SAMTOOLS" {
    memory = '8 GB'
    time   = '6h'
  }
  withName: "CALL_VARIANTS_CLAIR3" {
    memory = '10 GB'
    time   = '12h'
  }
}

apptainer {
  enabled    = true
  autoMounts = true
  cacheDir   = "/mnt/d/apptainer_cache"
}

profiles {
  singularity {
    singularity.enabled  = true
    process.executor     = 'local'
  }
  apptainer {
    apptainer.enabled    = true
    apptainer.autoMounts = true
    singularity.enabled  = false
    process.executor     = 'local'
  }
}

